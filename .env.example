# .env.example
# Use este arquivo como modelo. Copie para .env (raiz) e apps/web/.env

# --- SUPABASE (Frontend & Backend) ---
# Encontre em: Dashboard > Settings > API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJh...

# --- OAUTH: GOOGLE & GITHUB ---
# NOTA: Para o login funcionar no frontend (Supabase Auth), 
# configure as credenciais OAuth DIRETAMENTE NO DASHBOARD DO SUPABASE.
# Estas variáveis são para integrações específicas (ex: Google Drive no Frontend) ou uso no Backend se necessário.
VITE_GOOGLE_CLIENT_ID=
VITE_GOOGLE_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# --- BACKEND ONLY (Não incluir no Frontend) ---
# Necessário para scripts de administração backend da arquitetura
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJh...
SUPABASE_SERVICE_ROLE_KEY=eyJh... # CUIDADO: Acesso total ao banco, ignora RLS!

# --- GITHUB / CI ---
# Necessário para automações
GITHUB_TOKEN=ghp_...
GITHUB_ACTOR=username

APP_URL=https://app.leadgers.com

# --- VERCEL MCP ---
# Escopo: Apenas para este projeto (Leadgers). Crie um Token na Vercel exclusivo para ele via Dashboard > Tokens.
VERCEL_ACCESS_TOKEN=
VERCEL_TEAM_ID= # (Opcional) se o projeto estiver em um time
VERCEL_PROJECT_ID= # (Recomendado) para limitar o escopo ao projeto atual e não interferir em outros

# --- CONTEXT 7 MCP ---
# Focado em fornecer documentações atualizadas. Dispensa restrição de Workspace.
CONTEXT7_API_KEY=