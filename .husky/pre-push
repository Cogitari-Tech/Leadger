#!/usr/bin/env sh

if [ "$SKIP_PRE_PUSH" = "1" ]; then
  echo "⚠️ Skipping pre-push checks due to SKIP_PRE_PUSH=1"
  exit 0
fi

echo "🛡️  Running Pre-Push Verification..."

echo "📝 Analyzing types..."
npm run typecheck
if [ $? -ne 0 ]; then
  echo "🚨 Push rejected due to failing type checks."
  exit 1
fi

echo "🧪 Running tests..."
npm run test -- --run 2>/dev/null
if [ $? -ne 0 ]; then
  echo "🚨 Push rejected due to failing tests."
  exit 1
fi

echo "🔒 Running security scan..."
node scripts/security-scan.js
if [ $? -ne 0 ]; then
  echo "🚨 Push rejected due to failing security scan."
  exit 1
fi

echo "✅ Pre-push verification passed."
