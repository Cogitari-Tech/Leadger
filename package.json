{
  "name": "leadgers-platform",
  "version": "1.1.0",
  "description": "Sistema de Auditoria, Compliance e Gestão Financeira - Leadgers Governance",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=apps/web",
    "dev:api": "npm run dev --workspace=apps/api",
    "dev:all": "npm run dev:api & npm run dev",
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "test:watch": "npm run test:watch --workspace=packages/core",
    "test:e2e": "npm run test:e2e --workspace=apps/web",
    "test:integration": "npm run test:integration --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "clean": "rm -rf node_modules apps/*/node_modules packages/*/node_modules apps/*/dist packages/*/dist",
    "prepare": "husky",
    "security-check": "node scripts/security-scan.js",
    "mcp:setup": "cd tools/mcp && npm install"
  },
  "lint-staged": {
    "*": [
      "npm run security-check"
    ],
    "*.{js,jsx,ts,tsx}": [
      "prettier --write --ignore-unknown"
    ]
  },
  "devDependencies": {
    "@prisma/client": "^6.2.1",
    "@types/babel__traverse": "^7.28.0",
    "@types/d3-scale": "^4.0.9",
    "@types/d3-shape": "^3.1.8",
    "@types/node": "^20.11.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "eslint": "^8.56.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "pg": "^8.18.0",
    "prettier": "^3.2.4",
    "prisma": "^6.2.1",
    "rimraf": "^5.0.5",
    "supabase": "^2.76.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cogitari-Tech/Leadgers-Platform.git"
  },
  "author": "Leadgers Tech <devops@leadgers.com>",
  "license": "UNLICENSED",
  "dependencies": {
    "@modelcontextprotocol/server-github": "^2025.4.8",
    "@modelcontextprotocol/server-memory": "^2026.1.26",
    "@modelcontextprotocol/server-puppeteer": "^2025.5.12",
    "@modelcontextprotocol/server-sequential-thinking": "^2025.12.18",
    "@supabase/mcp-server-supabase": "^0.7.0",
    "@supabase/supabase-js": "^2.98.0",
    "@upstash/context7-mcp": "^2.1.6",
    "chrome-devtools-mcp": "^0.21.0",
    "mcp-remote": "^0.1.38",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "saxes": "^6.0.0",
    "vite": "^6.2.0",
    "vitest": "^3.0.7",
    "web-streams-polyfill": "^4.0.0-beta.3"
  },
  "overrides": {
    "tar": "^7.5.11",
    "minimatch": "^10.2.1",
    "flatted": "^3.4.0"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "^4.59.0"
  }
}
